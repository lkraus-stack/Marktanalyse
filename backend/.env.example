DATABASE_URL=sqlite+aiosqlite:///./market_intelligence.db
NEON_DATABASE_URL=postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/market_intelligence?sslmode=require
FRONTEND_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379/0
INTERNAL_API_KEY=change_me_for_production
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
FINNHUB_API_KEY=your_finnhub_api_key
COINGECKO_API_KEY=your_coingecko_demo_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
