AUTO_TRADER_MODE=manual
AUTO_IS_LIVE=false
AUTO_MAX_POSITION_SIZE_USD=1000
AUTO_MAX_POSITIONS=5
AUTO_MIN_SIGNAL_STRENGTH=60
AUTO_STOP_LOSS_PCT=5
AUTO_TAKE_PROFIT_PCT=10
AUTO_DOUBLE_CONFIRM_THRESHOLD_EUR=500
AUTO_DAILY_LOSS_LIMIT_EUR=100
AUTO_MAX_TRADES_PER_DAY=10
BINANCE_API_KEY=your_binance_api_key
ENABLE_SCHEDULER=false
