AI_CHAT_COMPLETIONS_PATH=/chat/completions
AI_MODEL=sonar
PERPLEXITY_API_KEY=your_perplexity_api_key
PERPLEXITY_DAILY_BUDGET_USD=0.5
PERPLEXITY_REQUEST_COST_USD=0.006
FINBERT_ENABLED=false
SENTIMENT_BATCH_SIZE=16
SENTIMENT_PROCESS_LIMIT=100
SIGNAL_WEIGHT_SENTIMENT=0.35
SIGNAL_WEIGHT_TECHNICAL=0.40
SIGNAL_WEIGHT_VOLUME=0.15
SIGNAL_WEIGHT_MOMENTUM=0.10
ALERT_COOLDOWN_MINUTES=60
ALERT_DELIVERY_RETRIES=2
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_USE_TLS=true
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_SECRET_KEY=your_kraken_secret_key
